    function testReadASN1ElementUnsuccessful() public {
        bytes memory data = hex"a1";
        bytes1 expectedTag = hex"12";
        (, , bool success) = nodePossessionVerifier.readASN1Element(data, expectedTag, false);
        assertEq(success, false);
    }

